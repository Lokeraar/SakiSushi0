# Examples of build artifacts, dependencies, and temporary files that should be ignored

# Compiled Python files
*.pyc
__pycache__/

# Build directories
build/
dist/
*.egg-info/

# Virtual environments
venv/
.venv/
env/

# Node.js dependencies
node_modules/

# Logs
*.log

# Temporary files
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swo

# OS files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo

# Gradle
.gradle/
target/

# MyPy cache
.mypy_cache/

# PyTest cache
.pytest_cache/